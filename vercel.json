{
  "functions": {
    "api/progress.py": {
      "runtime": "python3.9"
    }
  },
  "builds": [
    {
      "src": "api/progress.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/progress",
      "dest": "/api/progress.py"
    },
    {
      "src": "/api/health",
      "dest": "/api/progress.py"
    },
    {
      "src": "/api/books",
      "dest": "/api/progress.py"
    },
    {
      "src": "/api/books/(.*)",
      "dest": "/api/progress.py"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}